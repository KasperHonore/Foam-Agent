# Exclude runs directory (can be very large)
runs/

# Exclude generated outputs (often large)
output/
logs/
.venv/

# Host-side assets — used by the AI CLI on the host, never inside the container
examples/
tests/
agents/
.claude/
.codex/
.cursor/
.opencode/
.github/
.pytest_cache/
docs/

# Exclude Python cache files
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Exclude git files
.git/
.gitignore
.gitattributes

# Exclude IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Exclude test outputs and temporary files
*.log
*.tmp
*.bak

# Exclude database files (will be generated in container)
# Uncomment if you want to exclude pre-built database files
# database/faiss/
# database/raw/
